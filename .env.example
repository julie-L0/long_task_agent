LLM_API_BASE_URL=https://api.minimax.chat/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=MiniMax-M2.7

AGENT_NAME=小柳
TIMEZONE=Asia/Shanghai

# 通道：cli（默认，命令行）或 weixin（微信）
CHANNEL=cli

# Storage: local（默认，无需额外配置）or bitable（飞书多维表格云同步）
# 选 bitable 时运行 npm run setup 自动填充下方变量
STORAGE_BACKEND=local

# 飞书多维表格（STORAGE_BACKEND=bitable 时必填，由 npm run setup 自动生成，无需手填）
BITABLE_APP_TOKEN=
BITABLE_TABLE_TASKS=
BITABLE_TABLE_PROJECTS=
BITABLE_TABLE_REMINDERS=
BITABLE_TABLE_TIMELINE=
BITABLE_TABLE_PROGRESS_LOGS=
BITABLE_TABLE_USER_RULES=

# 微信 iLink Bot（CHANNEL=weixin 时必填，由 npm run weixin-login 自动生成，无需手填）
WEIXIN_BOT_TOKEN=
WEIXIN_BOT_ID=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_USER_ID=
WEIXIN_ALLOWED_USER_IDS=
